
pub struct:MyStruct = {
    wild uint32->:buf;
};

pub func:main = int32() {
    wild MyStruct->:s = @cast_unchecked<MyStruct->>(alloc(100i64));
    s->buf = @cast_unchecked<uint32->>(alloc(100i64));
    
    wildx uint32->:p11 = s->buf;
    wildx uint32->:r11 = @cast_unchecked<uint32->>(@cast_unchecked<int64>(p11) + (@cast_unchecked<int64>(5i64) * @sizeof(uint32)));

    exit(0i32);
};

pub func:failsafe = int32(tbb32:err) { exit(@cast_unchecked<int32>(err)); };
